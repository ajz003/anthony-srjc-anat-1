---

<SiteLayout
  title={pageTitle}
  siteTitle={siteTitle}
  description="An Astro + TypeScript tutor site for SRJC ANAT 1, modeled after a structured class resource page with topic navigation and grouped handouts."
>
  <main class="bg-white px-4 py-6 md:px-10 md:py-8">
    <div class="mb-1.5 text-[0.9rem] text-neutral-500">{siteTitle}</div>
    <h1 class="mb-5 text-[2rem] font-normal leading-tight text-neutral-800">
      {pageHeading}
    </h1>
    {
      groups.map((group) => (
        <section
          class="mt-8"
          aria-labelledby={group.title
            .toLowerCase()
            .replace(/[^a-z0-9]+/g, "-")}
        >
          <h2
            id={group.title.toLowerCase().replace(/[^a-z0-9]+/g, "-")}
            class="mb-2 text-[1.2rem] font-semibold text-neutral-800"
          >
            {group.title}
          </h2>
          {group.description && (
            <p class="mb-3.5 text-base text-neutral-500">{group.description}</p>
          )}
          <ul class="m-0 list-disc pl-[1.35rem]">
            {group.links.map((link) => (
              <li class="my-2">
                <a
                  href={link.url}
                  target={link.url.endsWith(".apkg") ? undefined : "_blank"}
                  rel={link.url.endsWith(".apkg") ? undefined : "noreferrer"}
                  download={link.url.endsWith(".apkg") ? true : undefined}
                  class="text-blue-700 underline-offset-2 hover:underline"
                >
                  {link.title}
                </a>
                {link.note && (
                  <div class="mt-0.5 text-[0.94rem] text-neutral-500">
                    {link.note}
                  </div>
                )}
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </main>
</SiteLayout>
